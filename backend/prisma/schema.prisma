// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USUARIOS DEL PANEL
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MEMBER)
  avatar    String?
  isActive  Boolean  @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  resetToken String?          // Token para restablecer contraseña
  resetExpires DateTime?      // Fecha de expiración del token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  comments       Comment[]
  assignedTickets Ticket[] @relation("AssignedTickets")
  ticketMessages TicketMessage[]
  projectPermissions UserProjectPermission[] // Proyectos a los que tiene acceso
  demoRequests   DemoRequest[]
  activityLogs   ActivityLog[]

  @@map("users")
}

// ==========================================
// PROYECTOS (agrupan sitios web)
// ==========================================
model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  clientName  String?
  clientEmail String?
  color       String  @default("#6366f1") // Color para el UI
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  sites Site[]
  userPermissions UserProjectPermission[]

  @@map("projects")
}

// ==========================================
// SITIOS WEB (pertenecen a un proyecto)
// ==========================================
model Site {
  id       String @id @default(uuid())
  name     String
  url      String
  sdkToken String @unique @default(uuid()) // Token único para autenticar el SDK
  mobileBreakpoint Int? @default(768)      // Breakpoint en px para clasificar vista PC/Celular

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  comments Comment[]

  @@index([projectId])
  @@map("sites")
}

// ==========================================
// COMENTARIOS / FEEDBACK VISUAL
// ==========================================
model Comment {
  id        String  @id @default(uuid())
  content   String  @db.Text
  guestName String?           // Nombre del visitante (Review Page)

  // Posición del clic (porcentajes relativos al viewport)
  xPercent Float
  yPercent Float

  // Contexto de la página
  pageUrl String
  pageTitle String?

  // Metadata del navegador (capturada por el SDK)
  browserName  String?
  browserVersion String?
  osName       String?
  osVersion    String?
  screenWidth  Int?
  screenHeight Int?
  viewportWidth  Int?
  viewportHeight Int?
  scrollX        Int?
  scrollY        Int?

  // Captura de pantalla
  screenshotUrl String?

  // Estado del comentario
  status CommentStatus @default(OPEN)

  // Relaciones
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  ticket Ticket?
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([authorId])
  @@index([createdAt])
  @@map("comments")
}

// ==========================================
// ADJUNTOS (archivos del feedback)
// ==========================================
model Attachment {
  id        String   @id @default(uuid())
  filename  String
  path      String
  mimetype  String
  size      Int

  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([commentId])
  @@map("attachments")
}

// ==========================================
// TICKETS (seguimiento de comentarios)
// ==========================================
model Ticket {
  id       String       @id @default(uuid())
  title    String
  priority Priority     @default(MEDIUM)
  category TicketCategory @default(OTHER)
  status   TicketStatus @default(OPEN)
  notes    String?      @db.Text

  // Asignado a un usuario del equipo
  assigneeId String?
  assignee   User?   @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Cada ticket viene de un comentario (1:1)
  commentId String  @unique
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // Mensajes internos del equipo
  messages  TicketMessage[]
  tags      TicketTag[]

  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([createdAt])
  @@map("tickets")
}

// ==========================================
// ENUMS
// ==========================================
enum UserRole {
  ADMIN
  MEMBER
  VIEWER
  DEMO
}

enum CommentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  UI_DESIGN
  BUG
  CONTENT
  PERFORMANCE
  OTHER
}

// ==========================================
// MENSAJES INTERNOS DE TICKETS
// ==========================================
model TicketMessage {
  id        String   @id @default(uuid())
  content   String   @db.Text
  guestName String?           // Nombre del visitante (respuesta del cliente)
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@index([authorId])
  @@map("ticket_messages")
}

// ==========================================
// PERMISOS DE USUARIO POR PROYECTO
// ==========================================
model UserProjectPermission {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  canView   Boolean  @default(true)   // Puede ver tickets/comentarios del proyecto
  canEdit   Boolean  @default(false)  // Puede modificar tickets
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_permissions")
}

// ==========================================
// AJUSTES DEL SISTEMA
// ==========================================
model SystemSetting {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ==========================================
// SOLICITUDES DE DEMO
// ==========================================
model DemoRequest {
  id        String     @id @default(uuid())
  name      String
  email     String
  ipAddress String
  status    DemoStatus @default(PENDING)
  expiresAt DateTime?

  // Si se aprueba, asociamos el usuario temporal
  demoUserId String?
  demoUser   User?     @relation(fields: [demoUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("demo_requests")
}

enum DemoStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ==========================================
// HISTORIAL DE ACTIVIDAD
// ==========================================
model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // LOGIN, LOGOUT, TICKET_CREATED, TICKET_STATUS_CHANGED, etc.
  entity    String?  // ticket, project, comment, user
  entityId  String?
  details   String?  @db.Text // JSON con detalles adicionales
  ipAddress String?

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==========================================
// TAGS / ETIQUETAS
// ==========================================
model Tag {
  id    String @id @default(uuid())
  name  String @unique
  color String @default("#6366f1")

  tickets TicketTag[]

  createdAt DateTime @default(now())

  @@map("tags")
}

model TicketTag {
  id       String @id @default(uuid())
  ticketId String
  tagId    String

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([ticketId, tagId])
  @@map("ticket_tags")
}
