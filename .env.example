# ==========================================
# VARIABLES DE ENTORNO PARA COOLIFY
# ==========================================

# Base de datos PostgreSQL en Coolify
POSTGRES_USER=imgcraetivo
POSTGRES_PASSWORD=tu_contrasena_super_segura_aqui
POSTGRES_DB=imgc_feedback

# Seguridad y Autenticación
JWT_SECRET=tu_jwt_secret_secreto_generado_aqui
JWT_EXPIRES_IN=7d
NODE_ENV=production

# URLs de Producción (Reemplazar con tus dominios reales en Coolify)
FRONTEND_URL=https://feedback.tudominio.com
BACKEND_URL=https://api-feedback.tudominio.com
VITE_API_URL=https://api-feedback.tudominio.com/api

# Integración con Supabase Storage (Opcional - para guardar imágenes fuera de la BD)
SUPABASE_URL=
SUPABASE_KEY=

# Clasificación de tickets por Inteligencia Artificial (Opcional)
GEMINI_API_KEY=

# Webhooks de Notificaciones (Opcional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
